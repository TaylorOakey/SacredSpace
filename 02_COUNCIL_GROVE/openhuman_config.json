  },
  "llm_cascade": [
    {
      "provider": "ollama",
      "endpoint": "http://localhost:11434",
      "models": ["mistral", "llama3", "phi3"],
      "priority": 1
    },
    {
      "provider": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com",
      "priority": 2
    }
  ],
  "fastapi_spine": {
    "base_url": "http://localhost:8888",
    "routes": {
      "health": "/health",
      "hermes_health": "/hermes/health",
      "mcp": "/mcp",
      "memory": "/memory",
      "pillars": "/pillars",
      "icaris": "/icaris",
