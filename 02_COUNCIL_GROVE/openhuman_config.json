{
  "app": "OpenHuman",
  "version": "1.0.0",
  "profile": "SacredSpace OS",
  "vault_path": "D:\\01_VAULT\\SacredSpace_Vault",
  "agentmemory_endpoint": "http://localhost:8888/mcp",
  "mcp_servers": {
    "sacredspace-hermes": {
      "endpoint": "http://localhost:8888/mcp",
      "name": "Hermes MCP",
      "description": "SacredSpace OS Hermes MCP server — memory, vault, agent orchestration",
      "version": "0.13.0",
      "status": "operational"
