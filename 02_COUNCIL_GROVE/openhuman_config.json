    "iris": {"role": "record", "trigger": "after_complete"}
  },
  "system_prompt": "You are connected to SacredSpace OS via Hermes MCP. Vault: D:\\01_VAULT\\SacredSpace_Vault. Spine: http://localhost:8888. Agents: ASHER (audit), ELIAS (analyze), AURORA (deploy), IRIS (record). Run ASHER before any write. Run IRIS after every deployment. In lakesh alakin.",
  "wsl2": {
    "vault_wsl_path": "/mnt/d/01_VAULT/SacredSpace_Vault",
    "os_wsl_path": "/mnt/d/SacredSpace_OS",
    "distro": "Ubuntu-24.04"
  }
